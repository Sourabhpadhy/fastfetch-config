# ==========================================
# ii FLAVOUR CONFIGURATION (qswitch)
# ==========================================
# All relative paths are absolute so qswitch can read them perfectly.

# -----------------------------------------------------
# 🟢 SAFE SOURCES (Visuals & Environment)
# -----------------------------------------------------
# These files only load ii's specific theme colors, environment
# variables, and shell daemon. They will not break your base setup.
source=~/.config/hypr/hyprland/env.conf
source=~/.config/hypr/hyprland/colors.conf
source=~/.config/hypr/hyprland/shellOverrides/main.conf


# -----------------------------------------------------
# 🟡 CAUTION SOURCES (Rules & Keybinds)
# -----------------------------------------------------
# These are left active so ii's menus and widgets work.
# WARNING: If ii's keybinds.conf has a shortcut like 'SUPER + Q', 
# it will overwrite the 'SUPER + Q' you set in your base config.
source=~/.config/hypr/hyprland/rules.conf
source=~/.config/hypr/hyprland/keybinds.conf


# -----------------------------------------------------
# 🔴 DANGEROUS SOURCES (COMMENTED OUT TO PROTECT SYSTEM)
# -----------------------------------------------------
# DO NOT uncomment these. If active, they will overwrite your 
# base hyprland.conf and actively harm your configuration.

# 1. OVERWRITES YOUR LAYOUT: 
# This file will completely destroy your 'scrolling' layout, gaps, 
# and custom border settings, forcing it back to dwindle/master.
# source=~/.config/hypr/hyprland/general.conf

# 2. OVERWRITES YOUR HARDWARE INPUTS:
# This file will overwrite your input {} block, messing up your 
# mouse sensitivity, keyboard layout, and touchpad gesture rules.
# source=~/.config/hypr/hyprland/variables.conf

# 3. CAUSES MEMORY LEAKS (DOUBLE EXECUTION):
# Your base config already launches nm-applet, cliphist, and Polkit. 
# Loading this file will launch them a second time, wasting RAM and 
# causing system tray glitches.
# source=~/.config/hypr/hyprland/execs.conf


# -----------------------------------------------------
# 🚫 CUSTOM FOLDER (DISABLED)
# -----------------------------------------------------
# Disabled to ensure no forgotten rules in the custom/ folder 
# secretly overwrite your base hyprland.conf. Your base config 
# is now the boss; you don't need these anymore.
# source=~/.config/hypr/custom/execs.conf
# source=~/.config/hypr/custom/general.conf
# source=~/.config/hypr/custom/rules.conf
# source=~/.config/hypr/custom/keybinds.conf
